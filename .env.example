# Redis 認証パスワード
# 設定すると redis コンテナに requirepass が適用され、
# backend も自動的にこのパスワードで接続します。
# ローカル開発では空のままでも動作します（認証無効）。
#
# 使用方法:
#   cp .env.example .env
#   .env を編集してパスワードを設定
#   docker compose up -d
REDIS_PASSWORD=

# OpenTelemetry（OTel Collectorを使う場合はコメントアウトを外す）
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Spring
SPRING_PROFILES_ACTIVE=docker
